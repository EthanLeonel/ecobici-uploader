# Nombre del bucket de Cloud Storage donde se guardarán los CSV
GCS_BUCKET_NAME=ecobici-raw-data

# Carpeta dentro del bucket (dejar en "raw" para datos crudos)
GCS_FOLDER=raw

# Credenciales locales (solo para desarrollo, NO en Cloud Run)
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/tu/service-account.json
